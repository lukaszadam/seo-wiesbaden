  address { font-style: normal; }

  /* ── NAV ── */
  #nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.4rem 0;
    transition: background .3s, padding .3s, border-color .3s;
    border-bottom: 1px solid transparent;
  }
  #nav.scrolled {
    background: rgba(12,21,39,.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    padding: .85rem 0;
    border-color: var(--bdr);
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 2rem;
    display: flex; align-items: center; gap: 2rem;
  }
  .logo { font-family: var(--serif); font-size: 1.55rem; font-weight: 700; }
  .logo-rank { color: var(--txt-hi); }
  .logo-rhein { color: var(--gold); }
  .nav-links { display: flex; gap: 2rem; margin-left: auto; }
  .nav-links a {
    font-size: .8rem; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; color: var(--txt);
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    font-size: .75rem; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--bg); background: var(--gold);
    padding: .6rem 1.4rem; border-radius: 2px;
    transition: background .2s, transform .15s; white-space: nowrap;
  }
  .nav-cta:hover { background: var(--gold-lt); transform: translateY(-1px); }
  .nav-burger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px; margin-left: auto;
  }
  .nav-burger span { display: block; width: 24px; height: 1.5px; background: var(--gold); transition: .3s; }
  .mobile-menu {
    display: none; flex-direction: column;
    background: rgba(12,21,39,.97); border-top: 1px solid var(--bdr);
    padding: 1.5rem 2rem 2rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-size: .9rem; font-weight: 500; padding: .75rem 0;
    border-bottom: 1px solid var(--bdr); color: var(--txt);
    transition: color .2s;
  }
  .mobile-menu a:hover { color: var(--gold); }
  .mobile-cta {
    margin-top: 1rem; text-align: center; border: 1px solid var(--gold) !important;
    color: var(--gold) !important; border-radius: 2px; font-weight: 700 !important;
  }

  /* ── HERO ── */
  #hero {
    position: relative; min-height: 100svh;
    display: flex; align-items: center;
    overflow: hidden; padding: 8rem 2rem 5rem;
  }
  .hero-bg-word {
    position: absolute; top: 50%; right: -4%;
    transform: translateY(-50%);
    font-family: var(--serif);
    font-size: clamp(180px, 28vw, 400px);
    font-weight: 700; line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(200,169,110,.055);
    pointer-events: none; user-select: none;
    letter-spacing: -.02em;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(200,169,110,.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,169,110,.035) 1px, transparent 1px);
    background-size: 64px 64px;
    pointer-events: none;
  }
  .hero-inner { position: relative; max-width: 1200px; margin: 0 auto; width: 100%; }
  .hero-tag {
    display: flex; align-items: center; gap: 1rem;
    font-size: .7rem; font-weight: 600; letter-spacing: .2em;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 2rem;
  }
  .tag-line { display: block; width: 36px; height: 1px; background: var(--gold); flex-shrink: 0; }
  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(4rem, 9.5vw, 9rem);
    font-weight: 600; letter-spacing: -.025em; line-height: .95;
    color: var(--txt-hi); margin-bottom: 2.5rem;
  }
  .hl-1, .hl-3 { display: block; }
  .hl-2 { display: block; color: var(--gold); font-style: italic; }
  .hero-sub {
    font-size: 1.1rem; line-height: 1.72;
    color: var(--txt); max-width: 520px; margin-bottom: 3rem;
  }
  .hero-actions { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: center; }
  .btn-primary {
    display: inline-flex; align-items: center;
    background: var(--gold); color: var(--bg);
    font-size: .82rem; font-weight: 700; letter-spacing: .07em;
    text-transform: uppercase; padding: 1rem 2.2rem; border-radius: 2px;
    transition: background .2s, transform .15s, box-shadow .2s;
  }
  .btn-primary:hover {
    background: var(--gold-lt); transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(200,169,110,.22);
  }
  .btn-ghost {
    display: inline-flex; align-items: center;
    color: var(--txt); font-size: .9rem; font-weight: 500;
    padding-bottom: 3px; border-bottom: 1px solid var(--bdr-hi);
    transition: color .2s, border-color .2s;
  }
  .btn-ghost:hover { color: var(--gold); border-color: var(--gold); }
  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: .75rem;
    font-size: .6rem; letter-spacing: .2em; text-transform: uppercase;
    color: var(--txt-dim);
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--gold-dk), transparent);
    animation: scrollPulse 1.6s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
    49%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
    50%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* ── STATS ── */
  #stats {
    background: var(--bg-mid);
    border-top: 1px solid var(--bdr);
    border-bottom: 1px solid var(--bdr);
  }
  .stats-inner {
    max-width: 1200px; margin: 0 auto; padding: 3rem 2rem;
    display: flex; justify-content: center; flex-wrap: wrap;
  }
  .stat {
    display: flex; flex-direction: column; align-items: center;
    gap: .35rem; padding: 1.5rem 3.5rem; text-align: center;
  }
  .stat-div { width: 1px; background: var(--bdr-hi); margin: 1rem 0; align-self: stretch; }
  .stat-n {
    font-family: var(--serif); font-size: 3.5rem;
    font-weight: 600; color: var(--txt-hi); line-height: 1;
  }
  .stat-n sup { font-size: 1.8rem; color: var(--gold); vertical-align: super; }
  .stat-l { font-size: .7rem; letter-spacing: .12em; text-transform: uppercase; color: var(--txt-dim); }

  /* ── SECTION COMMONS ── */
  .section-wrap { max-width: 1200px; margin: 0 auto; padding: 7rem 2rem; }
  .section-header { display: flex; align-items: flex-start; gap: 2.5rem; margin-bottom: 4.5rem; }
  .sec-num {
    font-family: var(--serif); font-size: 5.5rem; font-weight: 700;
    color: transparent; -webkit-text-stroke: 1px rgba(200,169,110,.18);
    line-height: 1; flex-shrink: 0; margin-top: -.4rem;
  }
  .sec-num-block {
    display: block; font-family: var(--serif); font-size: 4rem; font-weight: 700;
    color: transparent; -webkit-text-stroke: 1px rgba(200,169,110,.18);
    line-height: 1; margin-bottom: .5rem;
  }
  .sec-num-center {
    display: block; font-family: var(--serif); font-size: 4rem; font-weight: 700;
    color: transparent; -webkit-text-stroke: 1px rgba(200,169,110,.18);
    line-height: 1; text-align: center; margin-bottom: .75rem;
  }
  .sec-tag {
    display: flex; align-items: center; gap: .75rem;
    font-size: .68rem; font-weight: 600; letter-spacing: .2em;
    text-transform: uppercase; color: var(--gold); margin-bottom: .9rem;
  }
  .sec-tag-center { justify-content: center; }
  .sec-title { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 600; }

  /* ── LEISTUNGEN ── */
  #leistungen { border-top: 1px solid var(--bdr); }
  .services-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    border: 1px solid var(--bdr); gap: 1px; background: var(--bdr);
  }
  .svc-card {
    background: var(--bg); padding: 2.5rem;
    position: relative; overflow: hidden;
    transition: background .3s;
  }
  .svc-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--gold); transform: scaleX(0); transform-origin: left;
    transition: transform .4s ease;
  }
  .svc-card:hover { background: var(--bg-mid); }
  .svc-card:hover::before { transform: scaleX(1); }
  .svc-num {
    position: absolute; top: 1.5rem; right: 2rem;
    font-family: var(--serif); font-size: 5rem; font-weight: 700;
    color: transparent; -webkit-text-stroke: 1px rgba(200,169,110,.07);
    line-height: 1; pointer-events: none;
  }
  .svc-icon { width: 42px; height: 42px; color: var(--gold); margin-bottom: 1.5rem; }
  .svc-icon svg { width: 100%; height: 100%; }
  .svc-card h3 { font-size: 1.55rem; font-weight: 600; margin-bottom: 1rem; }
  .svc-card p { font-size: .88rem; line-height: 1.72; color: var(--txt); margin-bottom: 1.5rem; }
  .svc-list { display: flex; flex-direction: column; gap: .4rem; }
  .svc-list li {
    font-size: .78rem; color: var(--txt-dim);
    display: flex; align-items: center; gap: .6rem; letter-spacing: .02em;
  }
  .svc-list li::before { content: '—'; color: var(--gold); font-size: .7rem; flex-shrink: 0; }

  /* ── WARUM WIR ── */
  #warum-wir {
    background: var(--bg-mid);
    border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr);
  }
  .warum-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .warum-lead { font-size: 1rem; line-height: 1.72; color: var(--txt); margin-bottom: 2.5rem; }
  .warum-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .warum-list li { display: flex; gap: 1rem; align-items: flex-start; }
  .check-icon {
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(200,169,110,.08); border: 1px solid var(--bdr-hi);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold); font-size: .72rem; flex-shrink: 0; margin-top: .1rem;
  }
  .warum-list strong {
    display: block; font-size: .94rem; font-weight: 600;
    color: var(--txt-hi); margin-bottom: .2rem; font-family: var(--sans);
  }
  .warum-list p { font-size: .86rem; color: var(--txt); line-height: 1.62; }

  .warum-visual { display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; gap: 1rem; }
  .vis-card {
    background: var(--bg); border: 1px solid var(--bdr);
    border-radius: 6px; padding: 1.6rem;
  }
  .vis-big { grid-column: 1 / -1; }
  .vis-label {
    display: block; font-size: .65rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--txt-dim); margin-bottom: .5rem;
  }
  .vis-value {
    display: block; font-family: var(--serif); font-size: 2.6rem;
    font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 1.25rem;
  }
  .vis-bars { display: flex; align-items: flex-end; gap: 5px; height: 56px; }
  .vbar { flex: 1; background: rgba(200,169,110,.18); border-radius: 2px; }
  .vbar-gold { background: var(--gold); }
  .vis-period { display: block; font-size: .65rem; color: var(--txt-dim); margin-top: .75rem; letter-spacing: .1em; }
  .vis-big-num {
    display: block; font-family: var(--serif); font-size: 3rem;
    font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: .3rem;
  }
  .vis-kw { font-size: .72rem; color: var(--txt-dim); font-style: italic; }

  /* ── PROZESS ── */
  #prozess { border-top: 1px solid var(--bdr); }
  .prozess-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--bdr); border-right: none;
  }
  .pstep {
    padding: 2.5rem; border-right: 1px solid var(--bdr);
    transition: background .3s;
  }
  .pstep:hover { background: var(--bg-mid); }
  .pstep-num {
    font-family: var(--serif); font-size: 3.5rem; font-weight: 700;
    color: var(--gold); opacity: .45; line-height: 1; margin-bottom: 1.5rem;
  }
  .pstep h3 { font-size: 1.4rem; font-weight: 600; margin-bottom: .75rem; }
  .pstep p { font-size: .86rem; line-height: 1.7; color: var(--txt); }

  /* ── ERGEBNISSE ── */
  #ergebnisse {
    background: var(--bg-mid);
    border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr);
  }
  .results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .result-card {
    background: var(--bg); border: 1px solid var(--bdr);
    border-radius: 4px; padding: 2rem;
    position: relative; overflow: hidden;
    transition: border-color .3s, transform .25s;
  }
  .result-card::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }
  .result-card:hover { border-color: var(--bdr-hi); transform: translateY(-4px); }
  .res-cat {
    font-size: .67rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
  }
  .result-card h3 { font-size: 1.3rem; font-weight: 600; margin-bottom: 1rem; line-height: 1.25; }
  .result-card p { font-size: .86rem; line-height: 1.7; color: var(--txt); margin-bottom: 1.75rem; }
  .res-metrics {
    display: flex; gap: 1rem; padding-top: 1.25rem;
    border-top: 1px solid var(--bdr);
  }
  .res-metric { flex: 1; text-align: center; }
  .mval {
    display: block; font-family: var(--serif); font-size: 1.65rem;
    font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: .25rem;
  }
  .mlabel { display: block; font-size: .6rem; letter-spacing: .08em; color: var(--txt-dim); text-transform: uppercase; }

  /* ── KONTAKT ── */
  #kontakt { border-top: 1px solid var(--bdr); position: relative; overflow: hidden; }
  .kontakt-glow {
    position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(200,169,110,.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .kontakt-wrap {
    max-width: 720px; margin: 0 auto;
    padding: 7rem 2rem; text-align: center; position: relative;
  }
  .kontakt-title {
    font-family: var(--serif);
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    font-weight: 600; margin-bottom: 1.25rem; line-height: 1.08;
  }
  .kontakt-sub {
    font-size: 1rem; color: var(--txt); line-height: 1.72;
    margin-bottom: 3rem; max-width: 480px; margin-left: auto; margin-right: auto;
  }
  .kform { text-align: left; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .fg { display: flex; flex-direction: column; gap: .45rem; margin-bottom: 1rem; }
  .fg:last-of-type { margin-bottom: 0; }
  .fg label {
    font-size: .68rem; letter-spacing: .12em; text-transform: uppercase;
    color: var(--txt-dim); font-weight: 500;
  }
  .fg input, .fg textarea {
    background: var(--bg-mid); border: 1px solid var(--bdr);
    border-radius: 3px; padding: .9rem 1rem;
    color: var(--txt-hi); font-family: var(--sans); font-size: .9rem;
    outline: none; transition: border-color .2s; width: 100%;
  }
  .fg input::placeholder, .fg textarea::placeholder { color: var(--txt-dim); }
  .fg input:focus, .fg textarea:focus { border-color: var(--gold); }
  .fg textarea { resize: vertical; min-height: 110px; }
  .btn-submit {
    margin-top: 1.75rem; width: 100%;
    background: var(--gold); color: var(--bg);
    font-family: var(--sans); font-size: .88rem; font-weight: 700;
    letter-spacing: .07em; text-transform: uppercase;
    padding: 1.1rem 2rem; border-radius: 2px; border: none; cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
  }
  .btn-submit:hover {
    background: var(--gold-lt); transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(200,169,110,.2);
  }

  /* ── FOOTER ── */
  #footer { background: var(--bg); border-top: 1px solid var(--bdr); }
  .footer-wrap {
    max-width: 1200px; margin: 0 auto; padding: 4rem 2rem 3rem;
    display: grid; grid-template-columns: 2fr 2fr 1.5fr; gap: 4rem;
  }
  .footer-brand .logo { font-size: 1.65rem; display: inline-block; margin-bottom: 1rem; }
  .footer-brand p { font-size: .84rem; color: var(--txt-dim); line-height: 1.65; }
  .footer-links { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .footer-links strong {
    display: block; font-size: .65rem; letter-spacing: .16em;
    text-transform: uppercase; color: var(--txt-dim); margin-bottom: 1.2rem; font-weight: 600;
  }
  .footer-links ul { display: flex; flex-direction: column; gap: .55rem; }
  .footer-links a { font-size: .86rem; color: var(--txt); transition: color .2s; }
  .footer-links a:hover { color: var(--gold); }
  .footer-contact strong {
    display: block; font-size: .65rem; letter-spacing: .16em;
    text-transform: uppercase; color: var(--txt-dim); margin-bottom: 1.2rem;
  }
  .footer-contact p { font-size: .86rem; color: var(--txt); line-height: 1.7; margin-bottom: .75rem; }
  .footer-contact a { display: block; font-size: .86rem; color: var(--txt); margin-bottom: .4rem; transition: color .2s; }
  .footer-contact a:hover { color: var(--gold); }
  .footer-bottom {
    border-top: 1px solid var(--bdr);
    padding: 1.5rem 2rem;
    max-width: 1200px; margin: 0 auto;
  }
  .footer-bottom p { font-size: .72rem; color: var(--txt-dim); }
  .footer-bottom a { color: var(--txt-dim); transition: color .2s; }
  .footer-bottom a:hover { color: var(--gold); }

  /* ── FADE-UP ANIMATIONS ── */
  .fade-up {
    opacity: 0; transform: translateY(28px);
    transition: opacity .75s ease, transform .75s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .warum-wrap { grid-template-columns: 1fr; }
    .warum-visual { max-width: 480px; }
    .results-grid { grid-template-columns: 1fr 1fr; }
    .prozess-grid { grid-template-columns: 1fr 1fr; border-right: 1px solid var(--bdr); }
    .pstep:nth-child(2), .pstep:nth-child(4) { border-right: 1px solid var(--bdr); }
    .pstep:nth-child(1), .pstep:nth-child(2) { border-bottom: 1px solid var(--bdr); }
  }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .nav-burger { display: flex; }
    .hero-headline { font-size: clamp(3.5rem, 14vw, 5.5rem); }
    .stat-div { display: none; }
    .stats-inner { display: grid; grid-template-columns: 1fr 1fr; }
    .section-header { flex-direction: column; gap: 1rem; }
    .sec-num { font-size: 3rem; }
    .services-grid { grid-template-columns: 1fr; }
    .prozess-grid { grid-template-columns: 1fr; border-right: 1px solid var(--bdr); }
    .pstep { border-right: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr); }
    .results-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .footer-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
    .footer-links { grid-template-columns: 1fr 1fr; }
    .warum-wrap { gap: 3rem; }
    .warum-visual { max-width: 100%; }
  }

  @media (max-width: 480px) {
    .hero-headline { font-size: clamp(3rem, 16vw, 4.5rem); }
    .stat { padding: 1.25rem 1.5rem; }
    .stats-inner { grid-template-columns: 1fr 1fr; gap: 0; }
    .res-metrics { flex-direction: column; gap: .75rem; }
    .res-metric { text-align: left; }
  }
</style>
</body>
</html>
