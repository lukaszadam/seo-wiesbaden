---
const postModules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.values(postModules)
  .filter((post) => post.frontmatter.draft !== true)
  .sort((a, b) => new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf());
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SEO Blog | SEO Wiesbaden</title>
  <meta name="description" content="SEO-Wissen, Local-SEO-Ideen und praxisnahe Tipps für Unternehmen in Wiesbaden und dem Rhein-Main-Gebiet." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://seo-wiesbaden.de/blog" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="topbar">
    <a href="/" class="logo" aria-label="SEO Wiesbaden Startseite"><span>SEO </span><strong>Wiesbaden</strong></a>
    <a href="/" class="back-link">Startseite</a>
  </nav>

  <main>
    <header class="hero">
      <p class="eyebrow">Ratgeber</p>
      <h1>SEO Blog</h1>
      <p>Aktuelle SEO-Fragen, klare Antworten und umsetzbare Ideen für lokale Unternehmen.</p>
    </header>

    <section class="post-list" aria-label="Blogartikel">
      {posts.length === 0 ? (
        <p class="empty">Noch keine Blogartikel veröffentlicht.</p>
      ) : posts.map((post) => (
        <article class="post-card">
          <time datetime={post.frontmatter.pubDate}>{new Date(post.frontmatter.pubDate).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
          <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
          <p>{post.frontmatter.description}</p>
          <a class="read-link" href={post.url}>Artikel lesen</a>
        </article>
      ))}
    </section>
  </main>
</body>
</html>

<style>
  :root {
    --bg: #0C1527;
    --bg-mid: #101D34;
    --gold: #C8A96E;
    --txt: #B8B0A4;
    --txt-dim: #768096;
    --txt-hi: #EDE8DF;
    --bdr: rgba(200,169,110,0.14);
    --serif: Georgia, 'Times New Roman', serif;
    --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { min-height: 100vh; background: var(--bg); color: var(--txt); font-family: var(--sans); line-height: 1.7; }
  a { color: inherit; text-decoration: none; }
  .topbar { max-width: 1120px; margin: 0 auto; padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .logo { font-family: var(--serif); font-size: 1.55rem; font-weight: 700; color: var(--txt-hi); }
  .logo strong { color: var(--gold); }
  .back-link, .read-link { color: var(--gold); font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; border-bottom: 1px solid var(--bdr); }
  .back-link:hover, .read-link:hover { border-color: var(--gold); }
  main { max-width: 980px; margin: 0 auto; padding: 4rem 2rem 7rem; }
  .hero { border-bottom: 1px solid var(--bdr); padding-bottom: 3rem; margin-bottom: 3rem; }
  .eyebrow { color: var(--gold); font-size: .72rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; margin-bottom: 1rem; }
  h1, h2 { font-family: var(--serif); color: var(--txt-hi); font-weight: 600; line-height: 1.14; }
  h1 { font-size: clamp(3.2rem, 9vw, 6rem); margin-bottom: 1.2rem; }
  .hero p:not(.eyebrow) { max-width: 620px; font-size: 1.05rem; }
  .post-list { display: grid; gap: 1.25rem; }
  .post-card { border: 1px solid var(--bdr); background: var(--bg-mid); padding: 1.8rem; border-radius: 4px; }
  time { display: block; color: var(--txt-dim); font-size: .78rem; margin-bottom: .55rem; }
  .post-card h2 { font-size: clamp(1.55rem, 3vw, 2rem); margin-bottom: .8rem; }
  .post-card p { margin-bottom: 1.1rem; }
  .empty { color: var(--txt-dim); }
  @media (max-width: 640px) {
    .topbar { padding: 1.2rem 1.25rem; align-items: flex-start; flex-direction: column; }
    main { padding: 3rem 1.25rem 5rem; }
  }
</style>
