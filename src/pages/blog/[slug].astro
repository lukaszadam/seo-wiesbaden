---
export async function getStaticPaths() {
  const postModules = import.meta.glob('../../content/blog/*.md', { eager: true });
  const posts = Object.entries(postModules)
    .map(([file, post]) => ({ file, ...post }))
    .filter((post) => post.frontmatter.draft !== true);

  return posts.map((post) => ({
    params: { slug: post.frontmatter.slug ?? post.file.split('/').pop()?.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const Content = post.Content ?? post.default;
const canonical = `https://seo-wiesbaden.de/blog/${post.frontmatter.slug ?? Astro.params.slug}`;
const postTitle = cleanBlogTitle(post.frontmatter.title);

function cleanBlogTitle(value) {
  return String(value ?? '')
    .replace(/\bWiesbaden\w*\b/gi, '')
    .replace(/\s+([:|,-])/g, '$1')
    .replace(/([:|,-])\s*$/g, '')
    .replace(/\s{2,}/g, ' ')
    .trim();
}
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{postTitle}</title>
  <meta name="description" content={post.frontmatter.description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={postTitle} />
  <meta property="og:description" content={post.frontmatter.description} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: postTitle,
    description: post.frontmatter.description,
    datePublished: post.frontmatter.pubDate,
    dateModified: post.frontmatter.updatedDate ?? post.frontmatter.pubDate,
    author: {
      '@type': 'Organization',
      name: 'SEO Wiesbaden',
    },
    publisher: {
      '@type': 'Organization',
      name: 'SEO Wiesbaden',
    },
    mainEntityOfPage: canonical,
  })} />
</head>
<body>
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="logo" aria-label="SEO Wiesbaden Startseite"><span>SEO </span><strong>Wiesbaden</strong></a>
      <div class="nav-links">
        <a href="/#leistungen">Leistungen</a>
        <a href="/#prozess">Ablauf</a>
        <a href="/#ergebnisse">Ergebnisse</a>
        <a href="/blog" aria-current="page">Blog</a>
      </div>
      <a href="/#kontakt" class="nav-cta">Analyse anfragen</a>
    </div>
  </nav>

  <main>
    <article>
      <header class="hero">
        <p class="eyebrow">Ratgeber</p>
        <h1>{postTitle}</h1>
        <p>{post.frontmatter.description}</p>
        <time datetime={post.frontmatter.pubDate}>{new Date(post.frontmatter.pubDate).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
  </main>

  <footer class="site-footer">
    <div class="footer-wrap">
      <div>
        <a href="/" class="logo" aria-label="SEO Wiesbaden"><span>SEO </span><strong>Wiesbaden</strong></a>
        <p>Suchmaschinenoptimierung fuer Wiesbaden und den Rhein-Main-Raum.</p>
      </div>
      <nav class="footer-links" aria-label="Footer Navigation">
        <a href="/#leistungen">Leistungen</a>
        <a href="/blog">Blog</a>
        <a href="/datenschutz">Datenschutz</a>
        <a href="/impressum">Impressum</a>
      </nav>
    </div>
  </footer>
</body>
</html>

<style>
  :root {
    --bg: #0C1527;
    --bg-mid: #101D34;
    --gold: #C8A96E;
    --txt: #B8B0A4;
    --txt-dim: #768096;
    --txt-hi: #EDE8DF;
    --bdr: rgba(200,169,110,0.14);
    --serif: Georgia, 'Times New Roman', serif;
    --sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { min-height: 100vh; background: var(--bg); color: var(--txt); font-family: var(--sans); line-height: 1.75; }
  a { color: inherit; text-decoration: none; }
  .site-nav { border-bottom: 1px solid var(--bdr); background: rgba(12,21,39,.96); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 1rem 2rem; display: flex; align-items: center; gap: 2rem; }
  .logo { font-family: var(--serif); font-size: 1.55rem; font-weight: 700; color: var(--txt-hi); }
  .logo strong { color: var(--gold); }
  .nav-links { display: flex; gap: 1.6rem; margin-left: auto; }
  .nav-links a { color: var(--txt); font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; transition: color .2s; }
  .nav-links a:hover, .nav-links a[aria-current="page"] { color: var(--gold); }
  .nav-cta {
    background: var(--gold); color: var(--bg); border-radius: 2px;
    padding: .65rem 1.25rem; font-size: .74rem; font-weight: 800;
    letter-spacing: .08em; text-transform: uppercase; white-space: nowrap;
  }
  main { max-width: 880px; margin: 0 auto; padding: 4rem 2rem 7rem; }
  .hero { border-bottom: 1px solid var(--bdr); padding-bottom: 3rem; margin-bottom: 3rem; }
  .eyebrow { color: var(--gold); font-size: .72rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; margin-bottom: 1rem; }
  h1, h2, h3 { font-family: var(--serif); color: var(--txt-hi); font-weight: 600; line-height: 1.16; }
  h1 { font-size: clamp(2.8rem, 7vw, 5rem); margin-bottom: 1.25rem; }
  .hero p:not(.eyebrow) { max-width: 720px; font-size: 1.05rem; margin-bottom: 1rem; }
  time { color: var(--txt-dim); font-size: .82rem; }
  .content :global(h2) { font-size: clamp(1.7rem, 4vw, 2.35rem); margin: 2.5rem 0 .85rem; }
  .content :global(h3) { font-size: 1.45rem; margin: 2rem 0 .65rem; }
  .content :global(p), .content :global(li) { font-size: 1rem; }
  .content :global(p) { margin-bottom: 1rem; }
  .content :global(ul), .content :global(ol) { margin: 1rem 0 1.4rem 1.25rem; }
  .content :global(li) { margin-bottom: .45rem; }
  .content :global(a) { color: var(--gold); border-bottom: 1px solid var(--bdr); }
  .content :global(blockquote) { border-left: 2px solid var(--gold); padding-left: 1rem; color: var(--txt-hi); margin: 1.5rem 0; }
  .site-footer { border-top: 1px solid var(--bdr); }
  .footer-wrap { max-width: 1200px; margin: 0 auto; padding: 2.25rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .footer-wrap p { margin-top: .5rem; color: var(--txt-dim); font-size: .84rem; }
  .footer-links { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  .footer-links a { color: var(--txt-dim); font-size: .78rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
  .footer-links a:hover { color: var(--gold); }
  @media (max-width: 640px) {
    .nav-inner { padding: 1rem 1.25rem; align-items: flex-start; flex-direction: column; gap: 1rem; }
    .nav-links { margin-left: 0; flex-wrap: wrap; gap: .9rem 1.2rem; }
    .nav-cta { width: 100%; text-align: center; }
    main { padding: 3rem 1.25rem 5rem; }
    .footer-wrap { align-items: flex-start; flex-direction: column; padding: 2rem 1.25rem; }
  }
</style>
